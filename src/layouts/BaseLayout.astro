---
import '../styles/global.css';

const {
  title = 'La Jolla Centro Atletico — POC Astro',
  description = 'POC Astro per il redesign del sito La Jolla Centro Atletico.'
} = Astro.props;
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#10201d" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
