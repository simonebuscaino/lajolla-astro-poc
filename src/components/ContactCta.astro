---
const { phone, email, address, whatsapp, title = 'Prenota una valutazione iniziale.', text = 'Raccontaci il tuo obiettivo: ti aiuteremo a capire il percorso piu adatto tra performance, recupero e benessere.' } = Astro.props;
---
<section class="section contact" id="prenota">
  <div class="contact-copy">
    <span class="eyebrow">Contatti</span>
    <h2>{title}</h2>
    <p>{text}</p>
    <div class="contact-list" id="contatti">
      <a href={`tel:${phone?.replaceAll(' ', '')}`}>{phone}</a>
      <a href={`mailto:${email}`}>{email}</a>
      <span>{address}</span>
      {whatsapp && <a href={whatsapp}>WhatsApp</a>}
    </div>
  </div>
  <form class="lead-form" name="lead" method="post" data-netlify="true" netlify-honeypot="bot-field">
    <input type="hidden" name="form-name" value="lead" />
    <p class="hidden"><label>Non compilare<input name="bot-field" /></label></p>
    <label>Nome e cognome<input name="name" autocomplete="name" placeholder="Mario Rossi" required /></label>
    <label>Email<input name="email" type="email" autocomplete="email" placeholder="nome@email.it" required /></label>
    <label>Obiettivo<select name="goal" required><option>Preparazione atletica</option><option>Rieducazione funzionale</option><option>Posturale / schiena</option><option>Altro</option></select></label>
    <label>Messaggio<textarea name="message" rows="4" placeholder="Raccontaci di cosa hai bisogno"></textarea></label>
    <button class="button primary" type="submit">Invia richiesta</button>
    <p class="form-note">Rispondiamo usando i recapiti indicati nel modulo. Nessuna diagnosi viene fornita online.</p>
  </form>
</section>
