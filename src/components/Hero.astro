---
const { title, subtitle, heroImage, heroImageAlt, primaryCta, secondaryCta, proofPoints = [], phone, whatsapp } = Astro.props;
---
<section class="hero" id="top">
  <div class="hero-copy">
    <span class="eyebrow">Centro atletico a Torino</span>
    <h1>{title}</h1>
    <p class="hero-text">{subtitle}</p>
    <div class="hero-actions">
      <a class="button primary" href={whatsapp || '/contatti/'}>{primaryCta}</a>
      <a class="button secondary" href="/servizi/">{secondaryCta}</a>
      <a class="button ghost" href={`tel:${phone?.replaceAll(' ', '')}`}>Chiama ora</a>
    </div>
    <ul class="trust-row" aria-label="Punti di fiducia">
      {proofPoints.map((item) => <li>{item}</li>)}
    </ul>
  </div>

  <figure class="hero-visual">
    <img src={heroImage} alt={heroImageAlt} width="720" height="540" loading="eager" decoding="async" />
    <figcaption>
      <strong>Metodo La Jolla</strong>
      <span>Valutazione, progressione, follow-up</span>
    </figcaption>
  </figure>
</section>
